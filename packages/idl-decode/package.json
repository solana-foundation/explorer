{
    "name": "@explorer/idl-decode",
    "version": "0.0.0",
    "private": true,
    "files": [
        "dist"
    ],
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./anchor": {
            "types": "./dist/anchor/index.d.ts",
            "import": "./dist/anchor/index.js",
            "default": "./dist/anchor/index.js"
        },
        "./codama": {
            "types": "./dist/codama/index.d.ts",
            "import": "./dist/codama/index.js",
            "default": "./dist/codama/index.js"
        },
        "./fetch": {
            "types": "./dist/fetch/index.d.ts",
            "import": "./dist/fetch/index.js",
            "default": "./dist/fetch/index.js"
        }
    },
    "scripts": {
        "prebuild": "rm -rf dist",
        "build": "node scripts/build.mjs",
        "build:programs": "pnpm --filter \"@explorer/test-idl-program-*\" run build:anchor && node test-anchor-programs/copy-anchor-artifacts.mjs",
        "format": "oxfmt --check .",
        "format:fix": "oxfmt .",
        "lint": "oxlint && oxfmt --check .",
        "lint:fix": "oxlint --fix",
        "download:idls": "pnpm --filter \"@explorer/test-idl-program-*\" run download:idl",
        "generate:anchor-codama": "pnpm --filter \"./test-anchor-programs/*\" run generate:codama",
        "configure": "pnpm run download:idls && pnpm run generate",
        "generate": "pnpm run generate:anchor-codama && node scripts/generate-codama-literals.mjs && node scripts/generate-codama-types.mjs && pnpm run build",
        "pretest": "pnpm run generate",
        "test": "pnpm run typecheck && vitest run && pnpm run test:integration && pnpm run test:treeshakability && pnpm run test:node-esm && pnpm run test:coverage",
        "test:coverage": "vitest run --config vitest.coverage.config.ts && pnpm run test:type-coverage",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:type-coverage": "type-coverage -p tsconfig.build.json --strict --at-least 99.5",
        "test:node-esm": "for entry in dist/index.js dist/*/index.js; do node --input-type=module -e \"import('./$entry')\" || exit 1; done",
        "test:treeshakability": "for file in dist/index.js dist/*/index.js; do agadoo $file || exit 1; done",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit && tsc -p tsconfig.build.json --noEmit"
    },
    "dependencies": {
        "@codama/dynamic-parsers": "1.1.30",
        "@codama/nodes-from-anchor": "1.3.8"
    },
    "devDependencies": {
        "@codama/dynamic-client": "0.1.0",
        "@codama/dynamic-codecs": "1.1.30",
        "@codama/renderers-js": "^1.7.0",
        "@coral-xyz/anchor": "0.30.1",
        "@explorer/test-idl-program-amm-v3": "workspace:*",
        "@explorer/test-idl-program-dummy-transfer-hook": "workspace:*",
        "@explorer/test-idl-program-example-native-token-transfers": "workspace:*",
        "@explorer/test-idl-program-let-me-buy": "workspace:*",
        "@explorer/test-idl-program-memo": "workspace:*",
        "@explorer/test-idl-program-ntt-transceiver": "workspace:*",
        "@explorer/test-idl-program-simple": "workspace:*",
        "@explorer/test-idl-program-simple-031": "workspace:*",
        "@explorer/test-idl-program-tokenkeg": "workspace:*",
        "@explorer/test-idl-program-vault": "workspace:*",
        "@explorer/test-idl-program-wormhole-governance": "workspace:*",
        "@solana-program/program-metadata": "0.7.0",
        "@solana-program/token-2022": "0.9.0",
        "@solana/transaction-introspection": "7.0.0",
        "@vitest/coverage-v8": "catalog:vitest",
        "agadoo": "^3.0.0",
        "codama-fixtures": "https://codeload.github.com/codama-idl/codama/tar.gz/008849ce88472dc1080ed9a71a897b631de82b98",
        "oxc-transform": "^0.137.0",
        "oxfmt": "^0.56.0",
        "oxlint": "^1.71.0",
        "type-coverage": "^2.29.7",
        "typescript": "catalog:tooling",
        "vitest": "catalog:vitest"
    },
    "peerDependencies": {
        "@coral-xyz/anchor": "=0.30.1",
        "@solana-program/program-metadata": "^0.7.0",
        "@solana/kit": "^6.5.0",
        "codama": "^1.5.0"
    },
    "peerDependenciesMeta": {
        "@solana-program/program-metadata": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=18"
    }
}
