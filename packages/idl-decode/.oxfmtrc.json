{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "arrowParens": "avoid",
    "ignorePatterns": [".claude/", "**/__tests__/**/generated/", "**/*.idl.json", "**/*.md"],
    "printWidth": 120,
    "quoteProps": "as-needed",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4
}
